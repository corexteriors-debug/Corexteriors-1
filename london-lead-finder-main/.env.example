# Get your API key from https://console.cloud.google.com/
# Enable "Places API (New)" for your project
# Billing must be enabled (Google offers $200/month free credit)
GOOGLE_PLACES_API_KEY=your_api_key_here
# Budget limit in USD - searches stop before exceeding this
BUDGET_LIMIT_USD=150

# Google Sheets Integration (optional)
# Path to service account credentials JSON file
GOOGLE_SHEETS_CREDENTIALS=./service-account-key.json
# Your Google Spreadsheet ID (found in the URL)
GOOGLE_SHEET_ID=
# Auto-sync to Google Sheets after each search
AUTO_SYNC_SHEETS=true
