      "name": "Select One Queued (6am-9pm + cap)",
      "type": "n8n-nodes-base.function",
      "typeVersion": 2,
      "position": [
        -700,
        420
      ],
      "parameters": {
        "functionCode": "\nconst rows = items.map(i=>i.json);\nconst now = new Date();\nconst hhmm = now.toTimeString().slice(0,5);\nif (!(hhmm >= '06:00' && hhmm <= '21:00')) return [{ json: { mode:'outside_window' } }];\n\nconst sd = this.getWorkflowStaticData('global');\nconst today = now.toISOString().slice(0,10);\nif (sd.sendDate !== today){ sd.sendDate = today; sd.sentToday = 0; }\nconst cap = Number($node['Set Config'].json.dailySendCap || 40);\nif ((sd.sentToday || 0) >= cap) return [{ json: { mode:'cap_reached', sentToday: sd.sentToday, cap } }];\n\nfor (let i=0;i<rows.length;i++){\n  const r = rows[i];\n  const status = (r.Status||'').toString().toLowerCase();\n  const approved = (r['ApprovedToSend (Y/N)']||'').toString().toUpperCase();\n  const method = (r['Contact Method']||'Email').toString();\n  const email = (r['Contact Email']||'').toString();\n  if (status === 'queued' && approved === 'Y' && method === 'Email' && email){\n    return [{ json: { mode:'send', rowNumber: i+2, row: r } }];\n  }\n}\nreturn [{ json: { mode:'none' } }];\n"
      }
