      "parameters": {
        "functionCode": "\nlet p;\ntry { p = JSON.parse($json.message?.content || $json.text || '{}'); }\ncatch(e){ p = {variant:'A',score:60,priority:'Medium',recommendedServices:'',nextBestOffer:'Exterior audit',subject:'Quick exterior audit?',body:'',nextFollowUpDays:3}; }\nconst lead = $node['IF ContactMethod = Email'].json;\nconst nextFU = new Date(Date.now() + (p.nextFollowUpDays||3)*86400000).toISOString().slice(0,10);\nreturn [{\n  json: {\n    ...lead,\n    variant: p.variant,\n    leadScore: p.score,\n    priority: p.priority,\n    recommendedServices: p.recommendedServices,\n    nextBestOffer: p.nextBestOffer,\n    emailSubject: p.subject,\n    emailBody: p.body,\n    nextFollowUpDate: nextFU,\n    status: 'Queued',\n    approvedToSend: 'Y'\n  }\n}];\n"
